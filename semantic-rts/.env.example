# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: Google AI Studio API key (free tier at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_key_here

# Optional: path to Defects4J installation (set after running scripts/setup_defects4j.sh)
DEFECTS4J_HOME=/path/to/defects4j

# Optional: set to 1 to prevent any live LLM calls (uses cache only; raises on miss)
SRTS_CACHE_ONLY=0
